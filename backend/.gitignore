# ==========================================
# 1. SECURITY & COMPLIANCE (CRITICAL)
# ==========================================
# Never commit your environment variables or secrets!
.env
.env.*
!.env.example  # Keep the example file to show team members what variables they need

# ==========================================
# 2. PYTHON & VIRTUAL ENVIRONMENTS
# ==========================================
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/


# ==========================================
# 3. DATABASE & LOCAL DATA
# ==========================================
# Ignore local development databases
*.db
*.sqlite
*.sqlite3
database.db


# ==========================================
# 4. IDE & SYSTEM FILES
# ==========================================
.vscode/
.idea/
.DS_Store
.history/
.pytest_cache/
.coverage


# ==========================================
# 5. LOGS & TEMPORARY FILES
# ==========================================
*.log
tmp/


# Python / FastAPI
__pycache__/
*.py[cod]
*$py.class

